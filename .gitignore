# SLF Trap Detector - .gitignore
# ================================

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env
*.env
requirements_ci.txt

# ── IDE and Editors ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter Notebooks ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb~

# ── Data Files (Large/Sensitive) ─────────────────────────────────────────────
# Raw trap images - too large for git, store in data lake
data/raw/
data/processed/
data/external/

# Generated synthetic images - can be reproduced from code
data/synthetic/images/
outputs/synthetic/
outputs/sample_predictions/synthetic_inputs/images/

# Keep annotations and small reference files
!data/synthetic/annotations.json
!data/annotated/
!outputs/sample_predictions/synthetic_inputs/annotations.json

# ── Trained Models ──────────────────────────────────────────────────────────
# Store separately with DVC or model registry
outputs/models/
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx

# ── Logs and Temporary Files ─────────────────────────────────────────────────
logs/
*.log
*.out
*.err
tmp/
temp/
.cache/

# ── ML/Data Science ──────────────────────────────────────────────────────────
# MLflow tracking
mlruns/
.mlflow/

# Weights & Biases
wandb/

# DVC (Data Version Control)
.dvc/
*.dvc

# ── LaTeX ────────────────────────────────────────────────────────────────────
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb

# ── Benchmarking and Results ─────────────────────────────────────────────────
benchmark_results.json
evaluation_results/
experiments/

# ── Keep Important Outputs ──────────────────────────────────────────────────
# Keep a few sample prediction images for demos
!outputs/sample_predictions/result_000.jpg
!outputs/sample_predictions/result_001.jpg
!outputs/sample_predictions/result_002.jpg
!outputs/sample_predictions/before_after_comparison.jpg

# Keep compiled PDFs and documentation
!docs/*.pdf
!*.pdf

# ── CI/CD ───────────────────────────────────────────────────────────────────
# GitHub Actions artifacts
outputs/demo/ci_test/

# ── Label Studio ─────────────────────────────────────────────────────────────
# Export files from annotation sessions
label_studio_exports/
annotations_export/

# ── Docker ──────────────────────────────────────────────────────────────────
.dockerignore

# ── Configuration Overrides ─────────────────────────────────────────────────
# Local config overrides (secrets, API keys)
configs/local.yaml
configs/secrets.yaml
.env.local

# ── Large Files ─────────────────────────────────────────────────────────────
# Anything over 100MB should not be in git
*.zip
!slf-trap-detector-*.zip  # Allow distribution zips in releases

# ── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
.hypothesis/

# ── Package Management ──────────────────────────────────────────────────────
Pipfile.lock
poetry.lock

# ── Code Quality ────────────────────────────────────────────────────────────
.mypy_cache/
.black/
.ruff_cache/
